# Скопируй в .env (рядом с docker-compose.yml) и заполни.
# docker compose подхватывает .env автоматически.

# --- Публичные URL (нужны для Google OAuth redirect и cookie) ---
# Локальный запуск:
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
COOKIE_SECURE=False
# Через домен/Cloudflare Tunnel — раскомментируй и закомментируй локальные выше:
# FRONTEND_URL=https://msdig.kz
# BACKEND_URL=https://msdig.kz
# COOKIE_SECURE=True

# --- Безопасность ---
# Сгенерируй: openssl rand -hex 32
JWT_SECRET=dev_secret_change_me

# --- Google OAuth ---
# Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID (Web application).
# Authorized redirect URI должен совпадать с BACKEND_URL + /api/auth/google/callback
#   локально:   http://localhost:8000/api/auth/google/callback
#   на домене:  https://msdig.kz/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (письма подтверждения от info@msdig.kz) ---
# EMAIL_ENABLED=False -> код печатается в консоль бэкенда (dev, без отправки).
# Для реальной отправки нужен SMTP-провайдер, умеющий слать от info@msdig.kz
# (Cloudflare Email Routing только принимает письма, отправлять не умеет):
#   Brevo:  SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587
#   Zoho:   SMTP_HOST=smtp.zoho.com         SMTP_PORT=587
#   Resend: SMTP_HOST=smtp.resend.com       SMTP_PORT=587 (SMTP_USER=resend)
EMAIL_ENABLED=False
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=info@msdig.kz
