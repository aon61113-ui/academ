# ===== Database =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=academy
DB_PASSWORD=academy_pass
DB_NAME=digital_academy

# ===== JWT / Auth =====
# Сгенерируй: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_super_secret_key
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=14

# ===== CORS / URLs =====
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
# Включи только в проде (HTTPS) — ставит Secure-флаг на cookie
COOKIE_SECURE=false

# ===== Email (SMTP) =====
# При EMAIL_ENABLED=false коды печатаются в консоль (режим разработки)
EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@digital-academy.kz

# ===== Google OAuth 2.0 =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== reCAPTCHA v2/v3 =====
# При RECAPTCHA_ENABLED=false проверка пропускается (режим разработки)
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET=

# ===== Rate limiting =====
OTP_MAX_PER_HOUR=5
LOGIN_MAX_PER_15MIN=10
